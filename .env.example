# Beacon · CNIT 566 Final Project
# Author: Udaya Tejas
#
# The local-app branch needs almost no configuration.
# Copy this file to `.env.local` only if you want to override a default.

# ─── Local AI (Ollama) ───
# Install:  brew install ollama
# Run:      ollama serve &
# Pull:     ollama pull qwen2.5:7b
# Beacon auto-detects Ollama at the default endpoint. If it isn't running,
# all AI surfaces fall back to clearly-labelled demo responses.
# OLLAMA_ENDPOINT=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:7b

# ─── Brightspace (optional) ───
# Only needed if you want to sync your real Purdue Brightspace data into
# the local DB. The seed script (`npm run db:seed`) is enough for demos.
# BRIGHTSPACE_BASE_URL=https://purdue.brightspace.com

# ─── App ───
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Diagnostics ───
# DB_LOG=1                # echo every Drizzle SQL statement
# BEACON_SKIP_DB=1        # skip DB init (used internally during `next build`)
